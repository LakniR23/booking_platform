# Environment variables for QuickReserve Backend
# Copy this file to .env and fill in your values

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/booking_platform"

# JWT secret key — use a long random string in production
JWT_SECRET=your_jwt_secret_here

# JWT refresh secret key — use a different long random string in production
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# Access token expiration (default: 7d)
JWT_EXPIRES_IN=7d

# Refresh token expiration (default: 7d)
JWT_REFRESH_EXPIRES_IN=7d

# Server port (optional, defaults to 3000)
PORT=3000
